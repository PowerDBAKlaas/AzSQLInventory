    {
      "type": 1,
      "content": {
        "json": "# 🗄️ Azure SQL Monitoring Dashboard\n**Metrics-only · Free tier · No Log Analytics required**\n\n---"
      },
      "name": "title"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "Resources\n| where type in~ ('microsoft.sql/servers/databases', 'microsoft.sql/managedinstances', 'microsoft.sqlvirtualmachine/sqlvirtualmachines')\n| where not (type =~ 'microsoft.sql/servers/databases' and name == 'master')\n| summarize Count = count() by ResourceType = case(\n    type =~ 'microsoft.sql/servers/databases', '🗄️ SQL Databases',\n    type =~ 'microsoft.sql/managedinstances', '🏢 Managed Instances',\n    '🖥️ SQL VMs'\n  )\n| order by ResourceType asc",
        "size": 4,
        "title": "Resource Inventory",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": ["{Subscription}"],
        "visualization": "tiles",
        "tileSettings": {
          "showBorder": true,
          "titleContent": { "columnMatch": "ResourceType", "formatter": 1 },
          "leftContent": { "columnMatch": "Count", "formatter": 12, "formatOptions": { "palette": "blue" } }
        }
      },
      "name": "inventory-tiles"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "HealthResources\n| where type =~ 'microsoft.resourcehealth/availabilitystatuses'\n| where id has '/microsoft.sql/' or id has '/sqlvirtualmachines/'\n| extend ResourceName = tostring(split(id, '/')[-1])\n| extend State = tostring(properties.availabilityState)\n| extend Summary = tostring(properties.summary)\n| extend ResourceGroup = tostring(resourceGroup)\n| project ResourceName, ResourceGroup, State, Summary\n| order by State asc, ResourceName asc",
        "size": 1,
        "title": "🏥 Resource Health — All SQL Resources",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": ["{Subscription}"],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "State",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "icons",
                "thresholdsGrid": [
                  { "operator": "==", "thresholdValue": "Available", "representation": "success", "text": "{0}{1}" },
                  { "operator": "==", "thresholdValue": "Degraded", "representation": "warning", "text": "{0}{1}" },
                  { "operator": "==", "thresholdValue": "Unavailable", "representation": "failed", "text": "{0}{1}" },
                  { "operator": "Default", "thresholdValue": null, "representation": "unknown", "text": "{0}{1}" }
                ]
              }
            }
          ],
          "filter": true,
          "sortBy": [{ "itemKey": "State", "sortOrder": 2 }]
        }
      },
      "name": "resource-health"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "Resources\n| where type in~ ('microsoft.sql/servers/databases', 'microsoft.sql/managedinstances', 'microsoft.sqlvirtualmachine/sqlvirtualmachines')\n| where not (type =~ 'microsoft.sql/servers/databases' and name == 'master')\n| extend ResourceType = case(\n    type =~ 'microsoft.sql/servers/databases', 'SQL Database',\n    type =~ 'microsoft.sql/managedinstances', 'Managed Instance',\n    'SQL VM'\n  )\n| extend Tier = coalesce(tostring(sku.tier), tostring(sku.name), '-')\n| extend Capacity = tostring(sku.capacity)\n| extend Location = tostring(location)\n| project ResourceType, name, resourceGroup, Location, Tier, Capacity, id\n| order by ResourceType asc, name asc",
        "size": 1,
        "title": "📋 All SQL Resources",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": ["{Subscription}"],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "name",
              "formatter": 13,
              "formatOptions": { "linkTarget": "Resource", "linkIsContextBlade": true }
            },
            {
              "columnMatch": "ResourceType",
              "formatter": 1
            }
          ],
          "filter": true,
          "sortBy": [{ "itemKey": "ResourceType", "sortOrder": 1 }]
        }
      },
      "name": "inventory-table"
    },
