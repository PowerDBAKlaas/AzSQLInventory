    {
      "type": 1,
      "content": {
        "json": "# \ud83d\uddc4\ufe0f Azure SQL Monitoring Dashboard\n**Metrics-only \u00b7 Free tier \u00b7 No Log Analytics required**\n\n---"
      },
      "name": "title"
    },
    {
      "type": 1,
      "content": {
        "json": "## \ud83d\udea8 Subscription Health Overview\n> Subscriptions shown here have **unhealthy resources** or **fired metric alerts**. Green = nothing to check.\n\n---"
      },
      "name": "overview-header"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "HealthResources\n| where type =~ 'microsoft.resourcehealth/availabilitystatuses'\n| where id has '/microsoft.sql/' or id has '/sqlvirtualmachines/'\n| extend State = tostring(properties.availabilityState)\n| where State != 'Available'\n| join kind=leftouter (\n    ResourceContainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| extend ResourceName = tostring(split(id, '/')[-1])\n| summarize\n    IssueCount = count(),\n    States = strcat_array(make_set(State), ', '),\n    AffectedResources = strcat_array(make_set(ResourceName), ', ')\n    by SubscriptionName\n| order by IssueCount desc",
        "size": 1,
        "title": "\u26a0\ufe0f Resource Health Issues by Subscription",
        "noDataMessage": "\u2705 No resource health issues detected across all subscriptions.",
        "noDataMessageStyle": 3,
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "IssueCount",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "icons",
                "thresholdsGrid": [
                  {
                    "operator": ">",
                    "thresholdValue": "0",
                    "representation": "failed",
                    "text": "{0}"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "success",
                    "text": "{0}"
                  }
                ]
              }
            }
          ],
          "filter": true,
          "sortBy": [
            {
              "itemKey": "IssueCount",
              "sortOrder": 2
            }
          ]
        }
      },
      "customWidth": "50",
      "name": "overview-health-by-sub"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "AlertsManagementResources\n| where type =~ 'microsoft.alertsmanagement/alerts'\n| where properties.essentials.monitorCondition =~ 'Fired'\n| where properties.essentials.targetResourceType in~ (\n    'microsoft.sql/servers/databases',\n    'microsoft.sql/managedinstances',\n    'microsoft.compute/virtualmachines'\n  )\n| extend\n    AlertName    = tostring(properties.essentials.alertRule),\n    Severity     = tostring(properties.essentials.severity),\n    ResourceName = tostring(properties.essentials.targetResourceName),\n    FiredAt      = todatetime(properties.essentials.startDateTime)\n| join kind=leftouter (\n    ResourceContainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| summarize\n    FiredAlerts = count(),\n    Severities  = strcat_array(make_set(Severity), ', '),\n    AlertNames  = strcat_array(make_set(AlertName), ', '),\n    OldestFired = min(FiredAt)\n    by SubscriptionName\n| order by FiredAlerts desc",
        "size": 1,
        "title": "\ud83d\udd14 Fired Metric Alerts by Subscription",
        "noDataMessage": "\u2705 No fired alerts \u2014 either all clear, or no metric alerts have been configured yet.",
        "noDataMessageStyle": 3,
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "FiredAlerts",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "icons",
                "thresholdsGrid": [
                  {
                    "operator": ">",
                    "thresholdValue": "0",
                    "representation": "failed",
                    "text": "{0}"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "success",
                    "text": "{0}"
                  }
                ]
              }
            },
            {
              "columnMatch": "Severities",
              "formatter": 1
            }
          ],
          "filter": true,
          "sortBy": [
            {
              "itemKey": "FiredAlerts",
              "sortOrder": 2
            }
          ]
        }
      },
      "customWidth": "50",
      "name": "overview-alerts-by-sub"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "// All subscriptions that have SQL resources\nlet sqlSubs = Resources\n| where type in~ ('microsoft.sql/servers/databases','microsoft.sql/managedinstances','microsoft.sqlvirtualmachine/sqlvirtualmachines')\n| where not (type =~ 'microsoft.sql/servers/databases' and name == 'master')\n| distinct subscriptionId;\n// Subscriptions with health issues\nlet unhealthySubs = HealthResources\n| where type =~ 'microsoft.resourcehealth/availabilitystatuses'\n| where id has '/microsoft.sql/' or id has '/sqlvirtualmachines/'\n| where properties.availabilityState != 'Available'\n| distinct subscriptionId;\n// Subscriptions with fired alerts on SQL resources\nlet alertedSubs = AlertsManagementResources\n| where type =~ 'microsoft.alertsmanagement/alerts'\n| where properties.essentials.monitorCondition =~ 'Fired'\n| where properties.essentials.targetResourceType in~ ('microsoft.sql/servers/databases','microsoft.sql/managedinstances','microsoft.compute/virtualmachines')\n| distinct subscriptionId;\n// Clean subscriptions = have SQL resources but no issues\nsqlSubs\n| where subscriptionId !in (unhealthySubs) and subscriptionId !in (alertedSubs)\n| join kind=leftouter (\n    ResourceContainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| project SubscriptionName, Status = '\u2705 All Clear'\n| order by SubscriptionName asc",
        "size": 1,
        "title": "\u2705 Subscriptions \u2014 All Clear",
        "noDataMessage": "No subscriptions are fully clear \u2014 check the tables above.",
        "noDataMessageStyle": 2,
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "filter": true
        }
      },
      "customWidth": "50",
      "name": "overview-allclear"
    },
    {
      "type": 1,
      "content": {
        "json": "> \ud83d\udca1 **Note on storage % alerts:** The '\ud83d\udd14 Fired Alerts' panel above only shows issues if you have **metric alerts configured**. Without them, storage/CPU thresholds won't appear here. See the per-resource sections below for raw metric charts, or ask for a PowerShell script to bulk-create free metric alerts (storage >85%, CPU >90%) across all your databases.\n\n---"
      },
      "name": "overview-note"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "Resources\n| where type in~ ('microsoft.sql/servers/databases', 'microsoft.sql/managedinstances', 'microsoft.sqlvirtualmachine/sqlvirtualmachines')\n| where not (type =~ 'microsoft.sql/servers/databases' and name == 'master')\n| summarize Count = count() by ResourceType = case(\n    type =~ 'microsoft.sql/servers/databases', '\ud83d\uddc4\ufe0f SQL Databases',\n    type =~ 'microsoft.sql/managedinstances', '\ud83c\udfe2 Managed Instances',\n    '\ud83d\udda5\ufe0f SQL VMs'\n  )\n| order by ResourceType asc",
        "size": 4,
        "title": "Resource Inventory",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "tiles",
        "tileSettings": {
          "showBorder": true,
          "titleContent": {
            "columnMatch": "ResourceType",
            "formatter": 1
          },
          "leftContent": {
            "columnMatch": "Count",
            "formatter": 12,
            "formatOptions": {
              "palette": "blue"
            }
          }
        }
      },
      "name": "inventory-tiles"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "HealthResources\n| where type =~ 'microsoft.resourcehealth/availabilitystatuses'\n| where id has '/microsoft.sql/' or id has '/sqlvirtualmachines/'\n| extend ResourceName = tostring(split(id, '/')[-1])\n| extend State = tostring(properties.availabilityState)\n| extend Summary = tostring(properties.summary)\n| extend ResourceGroup = tostring(resourceGroup)\n| join kind=leftouter (\n    ResourceContainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| project ResourceName, SubscriptionName, ResourceGroup, State, Summary\n| order by State asc, SubscriptionName asc, ResourceName asc",
        "size": 1,
        "title": "\ud83c\udfe5 Resource Health \u2014 All SQL Resources",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "State",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "icons",
                "thresholdsGrid": [
                  {
                    "operator": "==",
                    "thresholdValue": "Available",
                    "representation": "success",
                    "text": "{0}{1}"
                  },
                  {
                    "operator": "==",
                    "thresholdValue": "Degraded",
                    "representation": "warning",
                    "text": "{0}{1}"
                  },
                  {
                    "operator": "==",
                    "thresholdValue": "Unavailable",
                    "representation": "failed",
                    "text": "{0}{1}"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "unknown",
                    "text": "{0}{1}"
                  }
                ]
              }
            }
          ],
          "filter": true,
          "sortBy": [
            {
              "itemKey": "State",
              "sortOrder": 2
            }
          ]
        }
      },
      "name": "resource-health"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "Resources\n| where type in~ ('microsoft.sql/servers/databases', 'microsoft.sql/managedinstances', 'microsoft.sqlvirtualmachine/sqlvirtualmachines')\n| where not (type =~ 'microsoft.sql/servers/databases' and name == 'master')\n| extend ResourceType = case(\n    type =~ 'microsoft.sql/servers/databases', 'SQL Database',\n    type =~ 'microsoft.sql/managedinstances', 'Managed Instance',\n    'SQL VM'\n  )\n| extend Tier = coalesce(tostring(sku.tier), tostring(sku.name), '-')\n| extend Capacity = tostring(sku.capacity)\n| extend Location = tostring(location)\n| join kind=leftouter (\n    ResourceContainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| project ResourceType, name, SubscriptionName, resourceGroup, Location, Tier, Capacity, id\n| order by SubscriptionName asc, ResourceType asc, name asc",
        "size": 1,
        "title": "\ud83d\udccb All SQL Resources",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "name",
              "formatter": 13,
              "formatOptions": {
                "linkTarget": "Resource",
                "linkIsContextBlade": true
              }
            },
            {
              "columnMatch": "ResourceType",
              "formatter": 1
            }
          ],
          "filter": true,
          "sortBy": [
            {
              "itemKey": "ResourceType",
              "sortOrder": 1
            }
          ]
        }
      },
      "name": "inventory-table"
    },
