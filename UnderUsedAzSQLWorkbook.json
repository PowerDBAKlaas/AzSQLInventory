        "style": "pills",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources"
      },
      "name": "parameters"
    },
    {
      "type": 1,
      "content": {
        "json": "# \ud83d\udca4 Azure SQL \u2014 Underused Resource Finder\n**Metrics-only \u00b7 Free tier \u00b7 No Log Analytics required**\n\n> Use a **7\u201330 day** time range for meaningful underuse detection. Single-day views hide weekly usage patterns.\n\n---"
      },
      "name": "title"
    },
    {
      "type": 1,
      "content": {
        "json": "## \u23f8\ufe0f Serverless / Paused Databases\nThese databases are **auto-paused** by Azure \u2014 definitively idle.\n"
      },
      "name": "paused-header"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "\nResources\n| where type =~ 'microsoft.sql/servers/databases'\n| where name != 'master'\n| where tostring(properties.currentServiceObjectiveName) =~ 'DataWarehouse'\n    or tostring(properties.status) =~ 'Paused'\n    or tostring(properties.currentServiceObjectiveName) contains 'Serverless'\n| join kind=leftouter (\n    ResourceContainers | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| extend\n    Status      = tostring(properties.status),\n    Tier        = tostring(sku.tier),\n    AllocatedGB = round(todouble(properties.maxSizeBytes) / 1073741824, 1)\n| project\n    ['Database']       = name,\n    SubscriptionName,\n    ['Resource Group'] = resourceGroup,\n    Tier, Status,\n    ['Allocated GB']   = AllocatedGB,\n    id\n| order by Status asc, ['Allocated GB'] desc\n",
        "size": 1,
        "title": "\u23f8\ufe0f Paused / Serverless Databases",
        "noDataMessage": "\u2705 No paused or serverless databases found.",
        "noDataMessageStyle": 3,
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "Database",
              "formatter": 13,
              "formatOptions": {
                "linkTarget": "Resource",
                "linkIsContextBlade": true
              }
            },
            {
              "columnMatch": "Status",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "icons",
                "thresholdsGrid": [
                  {
                    "operator": "==",
                    "thresholdValue": "Paused",
                    "representation": "unknown",
                    "text": "\u23f8\ufe0f Paused"
                  },
                  {
                    "operator": "==",
                    "thresholdValue": "Online",
                    "representation": "success",
                    "text": "\u2705 Online"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "failed",
                    "text": "{0}"
                  }
                ]
              }
            },
            {
              "columnMatch": "Allocated GB",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "colors",
                "thresholdsGrid": [
                  {
                    "operator": ">=",
                    "thresholdValue": "100",
                    "representation": "redBright",
                    "text": "{0} GB"
                  },
                  {
                    "operator": ">=",
                    "thresholdValue": "32",
                    "representation": "yellow",
                    "text": "{0} GB"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "blue",
                    "text": "{0} GB"
                  }
                ]
              }
            },
            {
              "columnMatch": "id",
              "formatter": 5
            }
          ],
          "filter": true
        }
      },
      "customWidth": "100",
      "name": "paused-grid"
    },
    {
      "type": 1,
      "content": {
        "json": "---\n## \ud83d\udcca All Databases \u2014 Sorted by Allocated Size\nLargest allocated databases first. Cross-reference with the metric charts below to identify those with high allocation but low actual usage.\n"
      },
      "name": "inv-header"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "\nResources\n| where type =~ 'microsoft.sql/servers/databases'\n| where name != 'master'\n| join kind=leftouter (\n    ResourceContainers | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| extend\n    Tier        = tostring(sku.tier),\n    Edition     = tostring(sku.name),\n    Capacity    = toint(sku.capacity),\n    AllocatedGB = round(todouble(properties.maxSizeBytes) / 1073741824, 1),\n    Status      = tostring(properties.status),\n    LicenseType = tostring(properties.licenseType)\n| extend\n    EstimatedTierCost = case(\n        Tier =~ 'Premium',  '\ud83d\udcb8 Premium \u2014 high cost',\n        Tier =~ 'BusinessCritical', '\ud83d\udcb8 Business Critical \u2014 high cost',\n        Tier =~ 'GeneralPurpose',   '\u26a0\ufe0f General Purpose',\n        Tier =~ 'Standard',         '\u2705 Standard',\n        Tier =~ 'Basic',            '\u2705 Basic',\n        '\u2753 Unknown'\n    )\n| project\n    ['Database']       = name,\n    SubscriptionName,\n    ['Resource Group'] = resourceGroup,\n    Tier,\n    Edition,\n    ['vCores / DTU']   = tostring(Capacity),\n    ['Allocated GB']   = AllocatedGB,\n    ['Tier Cost']      = EstimatedTierCost,\n    Status,\n    id\n| order by ['Allocated GB'] desc\n",
        "size": 1,
        "title": "\ud83d\udccb All Databases \u2014 Largest Allocated First (click name \u2192 Metrics blade)",
        "noDataMessage": "No results.",
        "noDataMessageStyle": 3,
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "Database",
              "formatter": 13,
              "formatOptions": {
                "linkTarget": "Resource",
                "linkIsContextBlade": true
              }
            },
            {
              "columnMatch": "Allocated GB",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "colors",
                "thresholdsGrid": [
                  {
                    "operator": ">=",
                    "thresholdValue": "500",
                    "representation": "redBright",
                    "text": "{0} GB"
                  },
                  {
                    "operator": ">=",
                    "thresholdValue": "100",
                    "representation": "yellow",
                    "text": "{0} GB"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "blue",
                    "text": "{0} GB"
                  }
                ]
              }
            },
            {
              "columnMatch": "Tier Cost",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "colors",
                "thresholdsGrid": [
                  {
                    "operator": "contains",
                    "thresholdValue": "\ud83d\udcb8",
                    "representation": "redBright",
                    "text": "{0}"
                  },
                  {
                    "operator": "contains",
                    "thresholdValue": "\u26a0\ufe0f",
                    "representation": "yellow",
                    "text": "{0}"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "green",
                    "text": "{0}"
                  }
                ]
              }
            },
            {
              "columnMatch": "id",
              "formatter": 5
            }
          ],
          "filter": true
        }
      },
      "customWidth": "100",
      "name": "inv-grid"
    },
    {
      "type": 1,
      "content": {
        "json": "---\n## \ud83d\udcc8 Usage Metrics \u2014 Underuse Signals\n> Lines consistently **below the green threshold** over the selected period are candidates for downsizing or removal.\n> **Click any line** in a chart to open that database's full Metrics blade.\n"
      },
      "name": "metrics-header"
    },
    {
      "type": 10,
      "content": {
        "version": "MetricsItem/2.0",
        "size": 0,
        "chartType": 2,
        "resourceType": "microsoft.sql/servers/databases",
        "metricScope": 0,
        "resourceIds": [
          "{SQLDBResources}"
        ],
        "timeContextFromParameter": "TimeRange",
        "metrics": [
          {
            "namespace": "microsoft.sql/servers/databases",
            "metric": "microsoft.sql/servers/databases--cpu_percent",
            "aggregation": 4,
            "splitBy": null
          }
        ],
        "title": "\u26a1 Avg CPU % \u2014 green line = 10% (underuse threshold)",
        "thresholds": [
          {
            "operator": "<=",
            "thresholdValue": 10,
            "borderColor": "green",
            "backgroundColor": "rgba(0,180,0,0.04)"
          }
        ]
      },
      "customWidth": "50",
      "name": "db-cpu-avg"
