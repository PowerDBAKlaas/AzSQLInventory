      "customWidth": "100",
      "name": "mi-inv-grid"
    },
    {
      "type": 10,
      "content": {
        "version": "MetricsItem/2.0",
        "size": 0,
        "chartType": 2,
        "resourceType": "microsoft.sql/managedinstances",
