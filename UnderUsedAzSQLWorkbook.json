    {
      "type": 1,
      "content": {
        "json": "---\n## \ud83c\udfe2 Managed Instances \u2014 Underuse Signals\n> MIs are expensive even when idle \u2014 a single GP/4vCore MI costs ~\u20ac450/month minimum.\n"
      },
      "name": "mi-header"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "\nResources\n| where type =~ 'microsoft.sql/managedinstances'\n| join kind=leftouter (\n    ResourceContainers | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| extend\n    vCores    = toint(sku.capacity),\n    Tier      = tostring(sku.tier),\n    StorageGB = toint(properties.storageSizeInGB),\n    State     = tostring(properties.state),\n    License   = tostring(properties.licenseType)\n| project\n    ['Managed Instance'] = name,\n    SubscriptionName,\n    ['Resource Group']   = resourceGroup,\n    Tier,\n    vCores,\n    ['Storage GB']       = StorageGB,\n    License,\n    State,\n    id\n| order by vCores desc, ['Storage GB'] desc\n",
        "size": 1,
        "title": "\ud83d\udccb All Managed Instances \u2014 sorted by vCores (highest cost first)",
        "noDataMessage": "No results.",
        "noDataMessageStyle": 3,
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "Managed Instance",
              "formatter": 13,
              "formatOptions": {
                "linkTarget": "Resource",
                "linkIsContextBlade": true
              }
            },
            {
              "columnMatch": "vCores",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "colors",
                "thresholdsGrid": [
                  {
                    "operator": ">=",
                    "thresholdValue": "16",
                    "representation": "redBright",
                    "text": "{0}"
                  },
                  {
                    "operator": ">=",
                    "thresholdValue": "8",
                    "representation": "yellow",
                    "text": "{0}"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "blue",
                    "text": "{0}"
                  }
                ]
              }
            },
            {
              "columnMatch": "Storage GB",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "colors",
                "thresholdsGrid": [
                  {
                    "operator": ">=",
                    "thresholdValue": "2048",
                    "representation": "redBright",
                    "text": "{0} GB"
                  },
                  {
                    "operator": ">=",
                    "thresholdValue": "512",
