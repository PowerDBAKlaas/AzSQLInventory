            "defaultValue": "value::all"
          },
          {
            "id": "p-time",
            "version": "KqlParameterItem/1.0",
            "name": "TimeRange",
            "label": "Time Range",
            "type": 4,
            "isRequired": true,
            "value": {
              "durationMs": 604800000
            },
            "typeSettings": {
              "selectableValues": [
                {
                  "durationMs": 86400000
                },
                {
                  "durationMs": 259200000
                },
                {
                  "durationMs": 604800000
                },
                {
                  "durationMs": 2592000000
                },
                {
                  "durationMs": 7776000000
                }
              ],
              "allowCustom": true
            }
          },
          {
            "id": "p-sqldb",
            "version": "KqlParameterItem/1.0",
            "name": "SQLDBResources",
            "label": "SQL Databases",
            "type": 5,
            "isRequired": false,
            "multiSelect": true,
            "query": "Resources\n| where type =~ 'microsoft.sql/servers/databases'\n| where name != 'master'\n| project id",
            "crossComponentResources": [
              "{Subscription}"
            ],
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "value": [
              "value::all"
            ],
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "showDefault": false
            }
          },
          {
            "id": "p-mi",
            "version": "KqlParameterItem/1.0",
            "name": "MIResources",
            "label": "Managed Instances",
            "type": 5,
            "isRequired": false,
            "multiSelect": true,
            "query": "Resources\n| where type =~ 'microsoft.sql/managedinstances'\n| project id",
            "crossComponentResources": [
              "{Subscription}"
            ],
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "value": [
              "value::all"
            ],
