    {
      "type": 1,
      "content": {
        "json": "---\n## \ud83c\udfe2 Managed Instances\n---"
      },
      "name": "mi-header"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "\nResources\n| where type =~ 'microsoft.sql/managedinstances'\n| join kind=leftouter (\n    ResourceContainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, SubscriptionName = name\n  ) on subscriptionId\n| extend\n    vCores       = tostring(sku.capacity),\n    Tier         = tostring(sku.tier),\n    StorageGB    = round(todouble(properties.storageSizeInGB), 0),\n    State        = tostring(properties.state),\n    LicenseType  = tostring(properties.licenseType)\n| project\n    ['Managed Instance'] = name,\n    SubscriptionName,\n    ['Resource Group']   = resourceGroup,\n    Tier, vCores,\n    ['Storage GB']       = StorageGB,\n    LicenseType, State,\n    id\n| order by ['Storage GB'] desc\n",
        "size": 1,
        "title": "\ud83d\udccb All Managed Instances \u2014 sorted by allocated storage",
        "noDataMessage": "No data found.",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "Managed Instance",
              "formatter": 13,
              "formatOptions": {
                "linkTarget": "Resource",
                "linkIsContextBlade": true
              }
            },
            {
              "columnMatch": "State",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "icons",
                "thresholdsGrid": [
                  {
                    "operator": "==",
                    "thresholdValue": "Ready",
                    "representation": "success",
                    "text": "{0}"
                  },
                  {
                    "operator": "Default",
